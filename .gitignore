# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
/build/                 # Python `build/` only at project root (paper LaTeX build dirs are tracked)
eggs/
*.whl

# Virtual environments
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/

# DeepSteer outputs - large logs and OS files excluded, data tracked
outputs/*.log
outputs/.DS_Store

# Paper PDFs (canonical build outputs from scripts/build_pdf.py).
# Treat as regenerable build artifacts for now; can flip to tracked
# later if we want collaborators to see the latest snapshot without
# rebuilding.
papers/*.pdf

# Downloaded caches (Gutenberg texts, etc.)
.cache/

# Environment and secrets
.env
*.pem

# Coding agents
.claude
